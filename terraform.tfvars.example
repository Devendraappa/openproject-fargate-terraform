# Example terraform.tfvars
# Replace the placeholder subnet IDs and VPC ID with real values from your AWS account.

vpc_id = "vpc-0123456789abcdef0"

public_subnet_ids = [
  "subnet-0aaa111bbb222ccc1",
  "subnet-0ddd333eee444fff2"
]

private_subnet_ids = [
  "subnet-01112223334445556",
  "subnet-06667778889990000"
]

# You can also set these via -var on the CLI when running terraform plan/apply.
